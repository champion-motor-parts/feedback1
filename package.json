{
  "name": "champion-feedback-mvp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0",
    "serve": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma db push && prisma db seed",
    "db:seed:reset": "node -e \"process.env.RESET_DEMO_DATA='1'; require('./prisma/seed.cjs')\""
  },
  "dependencies": {
    "@prisma/client": "6.9.0",
    "bcryptjs": "3.0.2",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.511.0",
    "next": "^16.2.9",
    "qrcode": "1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.3.1",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@types/node": "22.15.29",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.4",
    "prisma": "6.9.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  }
}
